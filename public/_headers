# Default: don't cache HTML pages (SPA catch-all).
# This ensures ANY route — including ones added in the future — gets fresh HTML.
# More-specific rules below override this where needed.
/*
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

# Cache control for versioned assets (with hash) - cache for 1 year
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Cache control for service worker (never cache)
/sw.js
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

# Cache control for manifest (daily cache)
/manifest.webmanifest
  Cache-Control: public, max-age=86400

/version.json
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

/ads.txt
  Cache-Control: no-cache, no-store, must-revalidate

