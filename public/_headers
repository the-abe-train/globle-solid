# Cache control for versioned assets (with hash) - cache for 1 year
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Cache control for index.html (never cache so users always get latest)
/
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

# Cache control for SPA routes (ensures deep links get fresh HTML)
/game
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

/practice
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

