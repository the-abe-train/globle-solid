# Cache control for service worker (never cache)
/sw.js
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

# Cache control for manifest (daily cache)
/manifest.webmanifest
  Cache-Control: public, max-age=86400

/version.json
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

/ads.txt
  Cache-Control: no-cache, no-store, must-revalidate

